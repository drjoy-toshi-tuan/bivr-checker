# ── Đăng nhập admin DrJOY (dùng cho check 'entity' — đối chiếu list エンティティ) ──
# Sao chép file này thành .env rồi điền giá trị. KHÔNG commit file .env.
DRJOY_ENV=master            # master hoặc demo (mặc định lấy theo tham số môi trường trên CLI)
DRJOY_USERNAME=toshituan
DRJOY_PASSWORD=
# (Tùy chọn) OAuth client cho endpoint cấp token, dạng "client_id:client_secret".
# Mặc định "demo:demo" (frontend admin dùng chung cho master & demo) — chỉ set khi client đổi.
# DRJOY_CLIENT_BASIC=demo:demo

# ── OpenAI (dùng cho các tính năng sau) ──
OPENAI_API_KEY=
